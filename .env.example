# Local-only Jarvis environment configuration
# This example includes only local/free components.
# Do not add paid/cloud keys here unless you plan to enable them.

# Application
DEBUG=True
LOG_LEVEL=INFO

# LLM Configuration
LLM_MODEL=qwen2.5:0.5b
OLLAMA_BASE_URL=http://localhost:11434
LLM_TEMPERATURE=0.2
LLM_NUM_PREDICT=80
LLM_REQUEST_TIMEOUT=45
WEB_SEARCH_ENABLED=True
WEB_SEARCH_RESULTS=3

# Voice Configuration
WAKE_WORD=jarvis
VOICE_OUTPUT=enabled
AUTO_START_VOICE_CONVERSATION=True
SPEECH_TO_TEXT_MODEL=tiny
STT_LANGUAGE=en
TTS_VOICE=en-US-AmberNeural
AUDIO_SAMPLE_RATE=16000
# Optional: set to a microphone device id or name from the `mics` command
# AUDIO_INPUT_DEVICE=
VOICE_LISTEN_DURATION=3
VOICE_MAX_EMPTY_ATTEMPTS=3
VOICE_STOP_KEYWORDS=stop,exit,quit,goodbye
VOICE_RESPONSE_MAX_WORDS=16
VOICE_MIN_PEAK_LEVEL=0.02

# Memory
MEMORY_TYPE=chroma
EMBEDDINGS_MODEL=all-MiniLM-L6-v2

# API
API_HOST=127.0.0.1
API_PORT=8000

# Database
DATABASE_URL=sqlite:///./data/jarvis.db

# OpenRouter (cloud, OpenAI-compatible) — OPTIONAL, paid.
# Enables the hybrid setup: fast/voice stay on local Ollama, while the brain
# (deep reasoning) and coder roles route to strong cloud models for accuracy.
# Paste your key below to turn it on; leave blank to stay fully local.
# Get a key at https://openrouter.ai/keys
# OPENROUTER_API_KEY=sk-or-...
# Defaults (override only if you want different models):
# Role map lives in LLM_ROLE_MODELS_JSON — "openrouter:" prefix = cloud, else local.
# LLM_ROLE_MODELS_JSON={"brain":"openrouter:deepseek/deepseek-r1","coder":"openrouter:anthropic/claude-sonnet-4","fast":"qwen2.5:0.5b","vision":"llava:7b"}

# Optional paid/cloud keys should be stored separately and only added when needed:
# OPENAI_API_KEY=
# HUGGINGFACEHUB_API_TOKEN=
# PINECONE_API_KEY=
# QDRANT_API_KEY=
# AZURE_OPENAI_KEY=
# AZURE_OPENAI_ENDPOINT=
# GITHUB_TOKEN=
